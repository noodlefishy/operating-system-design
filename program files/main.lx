main:
    movi r6, [stack]

	movi r1 [array]
    lw r2 [r1 + 0]
    push r2
    lw r1 [r1 + 1]
    movi r2 [itoaBuffer1]
    call itoa
    pop r1
   	movi r2 [itoaBuffer2]
    call itoa
    call str_cat
    call prints

    halt


itoaBuffer1: .space 13
itoaBuffer2: .space 6


numbers:
	.fill 10 // Number 1
	.fill 20 // Number 2

plus_str: .fill " + "
equals_str: .fill " = "
newline_str: .fill "\n"
array:
    .space 4

.space 30
