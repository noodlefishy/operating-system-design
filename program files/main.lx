main:
    movi r6 [stack]

	movi r2 [s1]
	movi r3 [s2]


	.loop:
		lw r4 [r2 + 0]
		lw r5 [r3 + 0]

		addi r2 r2 #1
		addi r3 r3 #1

		beq r4 r5 .loop

	.done:
		push r2
		movi r1 [notEq]
		call prints
		pop r2
		halt

s1: .fill "Hello" 	// 5
s2: .fill "Hello" 	// 6

// r2 = -256
// r3 = 12821

notEq: .fill "Not equal\n"
.space 30
stack: