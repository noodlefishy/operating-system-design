


// R3 = R1 * R2
multiply:
    push r4
    movi r3 0 // 3
    movi r4 0 // 4
    .loop: // 5
        addi r4 r4 1
        add r3 r3 r2
        beq r4 r1 .done
        beq r0 r0 .loop
.done:
    pop r4
    ret

// R1 = R1 - R2
subtract: // stackless
    push r2

    nand r2 r2 r2
    addi r2 r2 1
    add r1 r1 r2

    pop r2
    ret